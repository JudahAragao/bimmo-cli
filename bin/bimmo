#!/usr/bin/env node

// Silencia o aviso de depreciação do punycode que polui o terminal em versões novas do Node
process.removeAllListeners('warning');

import { program } from 'commander';
import { configure } from '../src/config.js';
import fs from 'fs';
import path from 'path';
import { fileURLToPath } from 'url';
import { createJiti } from 'jiti';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

// Usa jiti para carregar interface.jsx com suporte a JSX em tempo de execução
const jiti = createJiti(import.meta.url);
const { startInteractive } = await jiti.import('../src/interface.jsx');

const pkg = JSON.parse(fs.readFileSync(path.join(__dirname, '../package.json'), 'utf-8'));

program
  .name('bimmo')
  .description('bimmo — Sua IA universal no terminal (verde & lavanda)')
  .version(pkg.version);

program
  .command('config')
  .description('Configurar provedor e chave de API')
  .action(configure);

program.action(startInteractive);

program.parse();
