{
  "name": "bimmo-cli",
  "version": "4.1.9",
  "description": "🌿 Plataforma de IA universal profissional com interface React (Ink) pura.",
  "bin": {
    "bimmo": "bin/bimmo"
  },
  "type": "module",
  "keywords": [
    "ai",
    "cli",
    "ink",
    "react",
    "openai",
    "anthropic",
    "gemini",
    "agent",
    "swarm",
    "terminal"
  ],
  "author": "Judah",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JudahAragao/bimmo-cli.git"
  },
  "files": [
    "bin/",
    "src/",
    "README.md",
    ".bimmo-context.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rimraf dist && esbuild src/*.js src/**/*.js --format=esm --outdir=dist --platform=node --target=node20",
    "dev": "node bin/bimmo",
    "start": "npm run build && node bin/bimmo"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "rimraf": "^6.0.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@google/generative-ai": "^0.21.0",
    "@tavily/core": "^0.0.2",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "conf": "^13.0.0",
    "diff": "^7.0.0",
    "figlet": "^1.7.0",
    "fuzzy": "^0.1.3",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "inquirer": "^9.3.8",
    "marked": "^14.0.0",
    "marked-terminal": "^7.0.0",
    "mime-types": "^2.1.35",
    "ollama": "^0.5.12",
    "openai": "^4.82.0",
    "ora": "^8.1.1",
    "react": "^18.2.0",
    "zod": "^3.24.1"
  }
}
